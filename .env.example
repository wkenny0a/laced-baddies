SWELL_STORE_ID=
SWELL_PUBLIC_KEY=
SWELL_PRODUCT_ID=

# Optional: use separate Swell products for each plan/length combination.
SWELL_PRODUCT_ID_30_DAY_26=
SWELL_PRODUCT_ID_30_DAY_28=
SWELL_PRODUCT_ID_30_DAY_30=
SWELL_PRODUCT_ID_ONETIME_26=
SWELL_PRODUCT_ID_ONETIME_28=
SWELL_PRODUCT_ID_ONETIME_30=

# Optional: set these only if your Swell product uses matching options.
SWELL_LENGTH_OPTION_NAME=
SWELL_PLAN_OPTION_NAME=

# Optional: override Swell purchase options. Defaults are subscription for
# the 30-day club and standard for one-time purchase.
SWELL_PURCHASE_OPTION_30_DAY_TYPE=subscription
SWELL_PURCHASE_OPTION_30_DAY_PLAN_ID=
SWELL_PURCHASE_OPTION_ONETIME_TYPE=standard
SWELL_PURCHASE_OPTION_ONETIME_PLAN_ID=

# Optional fallback if your Swell cart does not return checkout_url.
SWELL_CHECKOUT_URL=

# Meta Pixel & Conversions API Settings (Direct Integration)
# The Meta Pixel ID (defaults to Laced Baddies Pixel if left blank)
META_PIXEL_ID=
# Conversions API System User Access Token generated in Events Manager
META_ACCESS_TOKEN=
# Optional test event code (e.g. TEST12345) to view events in Real-Time Test Events tab
META_TEST_EVENT_CODE=
